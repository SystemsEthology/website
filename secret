<!doctype html>
<html lang="ja">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Keyword Map</title>
  <style>
    body { font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif; margin: 16px; }
    #header { display: flex; flex-direction: column; gap: 6px; margin-bottom: 10px; }
    #participants { font-weight: 700; }
    #status { white-space: pre-wrap; color: #333; }
    svg { width: 100%; height: 78vh; border: 1px solid #ddd; border-radius: 10px; }
    .node text { pointer-events: none; font-size: 12px; }
  </style>
</head>
<body>
  <h2>Research Keyword Map</h2>

  <div id="header">
    <div id="participants">参加者数: -</div>
    <div id="status">loading...</div>
  </div>

  <svg id="viz"></svg>

  <script type="module">
    // ====== 設定 ======
    const SHEET_ID = "1ikru0FQrrGFDID1H1C3l_IFl8_5DtDio00XbdG5en1w";
    const GID = 0;                 // 通常、最初のタブは 0（必要なら #gid=... を確認して合わせる）
    const START_ROW = 2;           // B2
    const END_ROW = 10;            // B10
    const TARGET_COL_INDEX = 1;    // 0=A, 1=B
    const POLL_MS = 5 * 60 * 1000; // 5分
    const MAX_KEYWORDS = 250;
    const UMAP_NEIGHBORS = 15;
    const UMAP_MIN_DIST = 0.15;
    // ==================

    const statusEl = document.getElementById("status");
    const participantsEl = document.getElementById("participants");
    const svg = document.getElementById("viz");

    import * as d3 from "https://cdn.jsdelivr.net/npm/d3@7/+esm";
    import * as tf from "https://esm.sh/@tensorflow/tfjs";
    import * as use from "https://esm.sh/@tensorflow-models/universal-sentence-encoder";
    import { UMAP } from "https://esm.sh/umap-js";

    let model = null;

    function setStatus(msg) {
      const now = new Date();
      statusEl.textContent = `[${now.toLocaleString()}]\n${msg}`;
    }

    function setParticipants(n, totalSlots) {
      if (!Number.isInteger(n) || n < 0) throw new Error(`participant count invalid: ${n}`);
      participantsEl.textContent = `参加者数: ${n}${Number.isInteger(totalSlots) ? ` / ${totalSlots}` : ""}`;
    }

    // 区切り：カンマ(半/全), 読点、 句点。 改行 「」 のすべて
    const SPLIT_RE = /[,\uFF0C、。;\n\r「」]+/g;

    function csvUrl() {
      // 公開シートをCSVで取得（APIキー不要）
      // gvizは「シート全体CSV」を取って、こちらでB2-B10に切り出す
      return `https://docs.google.com/spreadsheets/d/${encodeURIComponent(SHEET_ID)}/gviz/tq?tqx=out:csv&gid=${encodeURIComponent(GID)}`;
    }

    async function fetchKeywordsFromSheet() {
      const res = await fetch(csvUrl(), { cache: "no-store" });
      if (!res.ok) throw new Error(`CSV fetch error: ${res.status} ${res.statusText}`);
      const text = await res.text();

      // CSVとして正しくパース（カンマ含むセルでも壊れない）
      const rows = d3.csvParse(text); // ヘッダ行をキーにしたオブジェクト配列
      if (!Array.isArray(rows)) throw new Error("CSV parse failed");

      // B2-B10 → rows[0] が2行目相当（ヘッダ除外済み）
      const startIdx = START_ROW - 2; // 2行目→0
      const endIdxExclusive = END_ROW - 1; // 10行目→9(排他的)
      const targetRows = rows.slice(startIdx, endIdxExclusive);

      const totalSlots = END_ROW - START_ROW + 1; // 9

      // B列を「2番目の列」として取得（列名に依存しない）
      const colNames = Object.keys(targetRows[0] ?? {});
      if (colNames.length <= TARGET_COL_INDEX) {
        throw new Error(`CSV column count too small: ${colNames.length}`);
      }
      const targetColName = colNames[TARGET_COL_INDEX];

      const cells = targetRows.map(r => (r?.[targetColName] ?? "").toString());
      const nonEmptyCells = cells.filter(s => s.trim().length > 0);
      const participantCount = nonEmptyCells.length; // 「回答数＝参加者数」

      // キーワード分解
      const tokens = [];
      for (const cell of nonEmptyCells) {
        const parts = cell.split(SPLIT_RE).map(s => s.trim()).filter(Boolean);
        tokens.push(...parts);
      }

      // 正規化＆頻度
      const freq = new Map();
      for (const t of tokens) {
        const norm = t.toLowerCase();
        freq.set(norm, (freq.get(norm) ?? 0) + 1);
      }

      const items = [...freq.entries()]
        .map(([key, count]) => ({ key, label: key, count }))
        .sort((a,b) => b.count - a.count)
        .slice(0, MAX_KEYWORDS);

      return { items, participantCount, totalSlots };
    }

    async function embedKeywords(items) {
      if (!model) {
        setStatus("Loading Universal Sentence Encoder model...");
        model = await use.load();
      }
      const texts = items.map(x => x.label);
      const emb = await model.embed(texts);
      const arr = await emb.array();
      emb.dispose();
      return arr;
    }

    function umap2d(vectors) {
      const umap = new UMAP({
        nNeighbors: UMAP_NEIGHBORS,
        minDist: UMAP_MIN_DIST,
        nComponents: 2,
        random: Math.random
      });
      return umap.fit(vectors);
    }

    function draw(items, coords) {
      const W = svg.clientWidth || 800;
      const H = svg.clientHeight || 600;

      svg.innerHTML = "";
      const root = d3.select(svg).attr("viewBox", `0 0 ${W} ${H}`);

      const padding = 40;

      const xs = coords.map(c => c[0]);
      const ys = coords.map(c => c[1]);

      const xScale = d3.scaleLinear().domain(d3.extent(xs)).range([padding, W - padding]);
      const yScale = d3.scaleLinear().domain(d3.extent(ys)).range([H - padding, padding]);

      const rScale = d3.scaleSqrt()
        .domain(d3.extent(items.map(d => d.count)))
        .range([10, 28]);

      const data = items.map((d, i) => ({
        ...d,
        x: xScale(coords[i][0]),
        y: yScale(coords[i][1]),
        r: rScale(d.count)
      }));

      const g = root.append("g");
      root.call(
        d3.zoom()
          .scaleExtent([0.5, 8])
          .on("zoom", (event) => g.attr("transform", event.transform))
      );

      const sim = d3.forceSimulation(data)
        .force("x", d3.forceX(d => d.x).strength(0.2))
        .force("y", d3.forceY(d => d.y).strength(0.2))
        .force("collide", d3.forceCollide(d => d.r + 2))
        .stop();

      for (let i = 0; i < 220; i++) sim.tick();

      const node = g.selectAll(".node")
        .data(data)
        .enter()
        .append("g")
        .attr("class", "node")
        .attr("transform", d => `translate(${d.x},${d.y})`);

      node.append("circle")
        .attr("r", d => d.r)
        .attr("fill", "white")
        .attr("stroke", "black")
        .attr("stroke-width", 1.2);

      node.append("title")
        .text(d => `${d.label} (keyword_count=${d.count})`);

      node.append("text")
        .attr("text-anchor", "middle")
        .attr("dominant-baseline", "middle")
        .text(d => d.label);

      root.append("text")
        .attr("x", 12)
        .attr("y", 20)
        .attr("font-size", 12)
        .text(`keywords=${data.length}  (zoom: wheel / drag)`);
    }

    async function updateOnce() {
      setStatus("Fetching responses (CSV)...");
      const { items, participantCount, totalSlots } = await fetchKeywordsFromSheet();
      setParticipants(participantCount, totalSlots);

      if (participantCount < 1) {
        setStatus("B2〜B10に有効な回答がありません。");
        svg.innerHTML = "";
        return;
      }
      if (items.length < 2) {
        setStatus(`キーワードが不足しています。keywords=${items.length}`);
        svg.innerHTML = "";
        return;
      }

      setStatus(`Embedding ${items.length} keywords (USE)...`);
      const vectors = await embedKeywords(items);

      setStatus("Projecting to 2D (UMAP) and rendering...");
      const coords = umap2d(vectors);

      if (coords.length !== items.length) {
        throw new Error(`internal mismatch: coords=${coords.length} items=${items.length}`);
      }

      draw(items, coords);
      setStatus(`Done. (next update in ${Math.round(POLL_MS/60000)} min)`);
    }

    async function main() {
      try { await updateOnce(); }
      catch (e) {
        console.error(e);
        setStatus(`ERROR:\n${e?.message ?? e}`);
      }
      setInterval(async () => {
        try { await updateOnce(); }
        catch (e) {
          console.error(e);
          setStatus(`ERROR:\n${e?.message ?? e}`);
        }
      }, POLL_MS);
    }

    main();
  </script>
</body>
</html>
